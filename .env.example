# Case App - Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE (fill in after creating project)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ===========================================
# CLOUDFLARE R2
# ===========================================
R2_ACCOUNT_ID=YOUR_R2_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=YOUR_R2_BUCKET_NAME
NEXT_PUBLIC_MEDIA_DOMAIN=YOUR_NEXT_PUBLIC_MEDIA_DOMAIN

# ===========================================
# PAYSTACK
# ===========================================
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=YOUR_PAYSTACK_PUBLIC_KEY
PAYSTACK_SECRET_KEY=YOUR_PAYSTACK_SECRET_KEY
# Set these after deploying:
# PAYSTACK_WEBHOOK_URL=https://your-domain.com/api/webhooks/paystack
# NEXT_PUBLIC_PAYSTACK_CALLBACK_URL=https://your-domain.com/dashboard/billing

# ===========================================
# APP CONFIG
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Case
